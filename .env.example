# Required — Supabase project credentials
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Required — public Supabase vars (used in browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required — public URL of this instance
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — AI features (Ask AI, summaries, Reading Memory)
# Pick ONE provider via AI_PROVIDER. If unset or incomplete, AI features are
# hidden in the UI — the app is fully functional without this.
AI_PROVIDER=            # anthropic | openai | ollama | custom

# --- Anthropic (AI_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6   # default, override to pin a different snapshot

# --- OpenAI (AI_PROVIDER=openai) ---
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.1   # default, verify current model availability

# --- Ollama, local (AI_PROVIDER=ollama) — no API key needed ---
# OLLAMA_BASE_URL=http://localhost:11434/v1   # default; from docker-compose use http://host.docker.internal:11434/v1 (Mac/Windows)
# OLLAMA_MODEL=llama3.1                        # default; must be pulled first: `ollama pull llama3.1`

# --- Any other OpenAI-compatible provider (AI_PROVIDER=custom) — Groq, Together, LM Studio, self-hosted vLLM ---
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# Optional — natural voice for Listen
# If omitted, Listen uses browser-native voice automatically.
ELEVENLABS_API_KEY=

# Optional — shared secret between web app and extractor sidecar
# If omitted, the extractor runs unauthenticated (fine for local dev behind Docker network).
# Set to any random string in production.
# NOTE: the web→extractor connection is plain HTTP on the Docker internal network.
# In cloud deployments (ECS, Fly.io, Render), ensure the sidecar is not publicly
# reachable and the internal network is isolated — do not expose port 8000 externally.
EXTRACTOR_SECRET=

# Optional — anonymous deployment ping (default: off)
# Set to true to send a daily anonymous ping (no personal data, no document data).
# MULL_PING=false
